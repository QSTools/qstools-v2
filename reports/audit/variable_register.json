  {
    "variable_name": "days_per_week",
    "owning_module": "Labour",
    "owning_file": "Labour input state",
    "variable_type": "input",
    "calculation_source": "User entered working pattern",
    "downstream_consumers": [
      "Labour calculations"
    ],
    "must_balance_to_pnl": false,
    "test_required": true,
    "notes": "Used to calculate daily_hours."
  },
  {
    "variable_name": "labour_rate",
    "owning_module": "Labour",
    "owning_file": "Labour input state",
    "variable_type": "input",
