    "owning_file": "Labour input state",
    "variable_type": "input",
    "calculation_source": "User entered productivity assumption",
    "downstream_consumers": [
      "Labour calculations",
      "Labour Scenario"
    ],
    "must_balance_to_pnl": false,
    "test_required": true,
    "notes": "Used to convert available hours to productive hours."
  },
  {
    "variable_name": "margin_target_percent",
    "owning_module": "Labour",
    "owning_file": "Labour input state",
    "variable_type": "input",
    "calculation_source": "User entered margin target",
    "downstream_consumers": [
      "Labour calculations",
      "Labour Scenario"
    ],
    "must_balance_to_pnl": false,
    "test_required": true,
    "notes": "Used to calculate minimum_charge_out_rate."
  },
  {
    "variable_name": "paid_hours_per_year",
    "owning_module": "Labour",
    "owning_file": "lib/calculations/labourCalculations.js",
    "variable_type": "calculated_output",
    "calculation_source": "hours_per_week * 52",
    "downstream_consumers": [
      "Labour UI",
      "Labour downstream outputs"
    ],
    "must_balance_to_pnl": false,
    "test_required": true,
    "notes": "Core Labour time output."
  },
  {
    "variable_name": "daily_hours",
    "owning_module": "Labour",
    "owning_file": "lib/calculations/labourCalculations.js",
    "variable_type": "calculated_output",
    "calculation_source": "hours_per_week / days_per_week",
    "downstream_consumers": [
      "Labour calculations"
    ],
    "must_balance_to_pnl": false,
    "test_required": true,
    "notes": "Used to convert entitlement days to hours."
  },
  {
    "variable_name": "non_productive_paid_hours",
    "owning_module": "Labour",
    "owning_file": "lib/calculations/labourCalculations.js",
    "variable_type": "calculated_output",
    "calculation_source": "leave + public holidays + sick + bereavement + family violence leave",
    "downstream_consumers": [
      "Labour UI",
      "Labour downstream outputs"
    ],
    "must_balance_to_pnl": false,
    "test_required": true,
    "notes": "Critical entitlement burden output."
  },
  {
    "variable_name": "productive_hours",
    "owning_module": "Labour",
    "owning_file": "lib/calculations/labourCalculations.js",
    "variable_type": "calculated_output",
    "calculation_source": "(paid_hours_per_year - non_productive_paid_hours) * productivity_percent",
    "downstream_consumers": [
      "Cost Summary",
      "Recovery Summary through Cost Summary"
    ],
    "must_balance_to_pnl": false,
    "test_required": true,
    "notes": "Cost Summary consumes this as productive output. Must not be rebuilt downstream."
  },
  {
    "variable_name": "base_labour_cost_annual",
    "owning_module": "Labour",
    "owning_file": "lib/calculations/labourCalculations.js",
    "variable_type": "calculated_output",
    "calculation_source": "labour_rate * paid_hours_per_year",
    "downstream_consumers": [
      "Labour UI"
    ],
    "must_balance_to_pnl": false,
    "test_required": true,
    "notes": "Annual gross wage base before employer contributions."
  },
  {
    "variable_name": "gross_wages_annual",
    "owning_module": "Labour",
    "owning_file": "lib/calculations/labourCalculations.js",
    "variable_type": "downstream_contract_output",
    "calculation_source": "base_labour_cost_annual",
    "downstream_consumers": [
      "Cost Summary"
    ],
    "must_balance_to_pnl": true,
    "test_required": true,
    "notes": "Locked Labour output consumed by Cost Summary."
  },
  {
    "variable_name": "entitlements_annual",
    "owning_module": "Labour",
    "owning_file": "lib/calculations/labourCalculations.js",
    "variable_type": "downstream_contract_output",
    "calculation_source": "labour_rate * non_productive_paid_hours",
    "downstream_consumers": [
      "Cost Summary"
    ],
    "must_balance_to_pnl": true,
    "test_required": true,
    "notes": "Locked Labour output consumed by Cost Summary."
  },
  {
    "variable_name": "employer_kiwisaver_gross",
    "owning_module": "Labour",
    "owning_file": "lib/calculations/labourCalculations.js",
    "variable_type": "downstream_contract_output",
    "calculation_source": "labour_rate * paid_hours_per_year * employer_kiwisaver_rate",
    "downstream_consumers": [
      "Cost Summary"
    ],
    "must_balance_to_pnl": true,
    "test_required": true,
    "notes": "Locked Labour output consumed by Cost Summary."
  },
  {
    "variable_name": "esct_rate",
    "owning_module": "Labour",
    "owning_file": "lib/calculations/labourCalculations.js",
    "variable_type": "calculated_output",
    "calculation_source": "Derived ESCT band result",
    "downstream_consumers": [
      "Labour UI"
    ],
    "must_balance_to_pnl": false,
    "test_required": true,
    "notes": "Must represent derived band result, not universal hardcoded assumption."
  },
  {
    "variable_name": "esct_amount",
    "owning_module": "Labour",
    "owning_file": "lib/calculations/labourCalculations.js",
    "variable_type": "downstream_contract_output",
    "calculation_source": "employer_kiwisaver_gross * derived esct_rate",
    "downstream_consumers": [
      "Cost Summary"
    ],
    "must_balance_to_pnl": true,
    "test_required": true,
    "notes": "Locked Labour output consumed by Cost Summary."
  },
  {
    "variable_name": "total_employer_contribution_cost",
    "owning_module": "Labour",
    "owning_file": "lib/calculations/labourCalculations.js",
    "variable_type": "downstream_contract_output",
    "calculation_source": "employer_kiwisaver_gross + esct_amount",
