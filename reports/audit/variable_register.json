      "Cost Summary",
      "Labour UI"
    ],
    "must_balance_to_pnl": true,
    "test_required": true,
    "notes": "Subtotal only. KiwiSaver and ESCT must remain separately visible."
  },
  {
    "variable_name": "total_labour_cost_annual",
    "owning_module": "Labour",
    "owning_file": "lib/calculations/labourCalculations.js",
    "variable_type": "calculated_output",
    "calculation_source": "base_labour_cost_annual + total_employer_contribution_cost",
    "downstream_consumers": [
      "Labour UI"
    ],
    "must_balance_to_pnl": false,
    "test_required": true,
    "notes": "Labour-only annual burden before Employee Overheads."
  },
  {
    "variable_name": "loaded_labour_cost_rate",
    "owning_module": "Labour",
    "owning_file": "lib/calculations/labourCalculations.js",
    "variable_type": "calculated_output",
    "calculation_source": "total_labour_cost_annual / paid_hours_per_year",
    "downstream_consumers": [
      "Labour UI"
    ],
    "must_balance_to_pnl": false,
    "test_required": true,
    "notes": "Loaded rate over paid hours."
  },
  {
    "variable_name": "productive_labour_cost_rate",
    "owning_module": "Labour",
    "owning_file": "lib/calculations/labourCalculations.js",
    "variable_type": "calculated_output",
