    "owning_file": "lib/calculations/labourCalculations.js",
    "variable_type": "calculated_output",
    "calculation_source": "productive_labour_cost_rate / (1 - margin_target_percent)",
    "downstream_consumers": [
      "Labour UI",
      "Labour Scenario"
    ],
    "must_balance_to_pnl": false,
    "test_required": true,
    "notes": "Critical Labour recovery threshold."
  },
